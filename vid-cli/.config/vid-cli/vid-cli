        [ -z "$mode" ] && { echo "👋 Goodbye."; exit 0; }

        case "$mode" in
            *"Watch Videos"*)
                video_mode=$(printf "  🏠  YouTube Home\n  🌐  Search YouTube\n  📂  Play from downloads\n  ↩   Back" \
                    | fzf --prompt="  ❯ " \
                          --border=rounded \
                          --layout=reverse \
                          --height=10 \
                          --no-info \
                          --color="prompt:#00afff,pointer:#00afff,hl:#00afff,hl+:#00afff")
                [[ -z "$video_mode" || "$video_mode" == *"Back"* ]] && continue

                if [[ "$video_mode" == *"YouTube Home"* ]]; then
                    youtube_home_page

                elif [[ "$video_mode" == *"Search YouTube"* ]]; then
                    last_query=""
                    while true; do
                        raw=$(run_search "🔍 Search YouTube: " "$last_query")
