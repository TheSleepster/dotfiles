                    mpv --config-dir="$HOME/.config/mpv" --hwdec=auto-safe "$DOWNLOAD_DIR/$selected_file" >/dev/null 2>&1
                    echo "✅ Playback finished."
                fi
                ;;

            *"Download Audio"*)
                audio_download_flow
                ;;
        esac
    done

else
    # Launched with a query arg — one-shot search (channels/playlists/videos)
    _write_yt_search_script
    rm -f /tmp/vid-cli-yt-cache.txt /tmp/vid-cli-yt-last-query
    selected=$(bash /tmp/vid-cli-yt-search.sh "$query" \
