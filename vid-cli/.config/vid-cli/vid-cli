                metaflac --set-tag="ARTIST=${_artist}" "$found" 2>>"$logfile"
                [[ -n "$_album" ]] &&                     metaflac --set-tag="ALBUM=${_album}" "$found" 2>>"$logfile"
                [[ -s "$cover_file" ]] &&                     metaflac --import-picture-from="3||||${cover_file}"                         "$found" 2>>"$logfile"
                ;;
            mp3)
                # ffmpeg -c copy embeds ID3 tags without re-encoding
                local _fargs=(-i "$found" -map 0 -c copy
                    -metadata "title=${_title}"
                    -metadata "artist=${_artist}")
                [[ -n "$_album" ]] && _fargs+=(-metadata "album=${_album}")
                [[ -s "$cover_file" ]] &&                     _fargs+=(-i "$cover_file" -map 0 -map 1                              -metadata:s:v title="Album cover"                              -metadata:s:v comment="Cover (front)")
                ffmpeg -loglevel error "${_fargs[@]}" "$_tmp" >> "$logfile" 2>&1                     && mv "$_tmp" "$found" || rm -f "$_tmp"
                ;;
            *)
                # WAV/other: ffmpeg for metadata
                ffmpeg -loglevel error                     -i "$found" -map 0 -c copy                     -metadata "title=${_title}"                     -metadata "artist=${_artist}"                     ${_album:+-metadata "album=${_album}"}                     "$_tmp" >> "$logfile" 2>&1                     && mv "$_tmp" "$found" || rm -f "$_tmp"
                ;;
        esac

        rm -f "$cover_file"
        echo "OK" > "$donefile"
        exit 0
    ) &

    AUDIO_JOBS+=("$!|$label|$dest_dir|$ext|$logfile|$donefile")
}

