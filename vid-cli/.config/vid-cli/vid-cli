# --- 1. SETUP & ARGUMENTS ---

check_dependencies "yt-dlp" "fzf" "mpv" "awk" "ffmpeg" "chafa" "curl" "sqlite3" "metaflac"

# Load or create config
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/vid-cli"
CONFIG_FILE="$CONFIG_DIR/config"
if [ ! -f "$CONFIG_FILE" ]; then
    mkdir -p "$CONFIG_DIR"
    printf "# vid-cli config\n# Browser to read cookies from\nBROWSER=firefox\n\n# Override default paths (optional):\n# DOWNLOAD_DIR=$HOME/videos\n# MUSIC_DIR=$HOME/Music\n\n"  > "$CONFIG_FILE"
fi
# shellcheck source=/dev/null
source "$CONFIG_FILE"
BROWSER="${BROWSER:-firefox}"
COOKIES_FILE="${CONFIG_DIR}/cookies.txt"

# Returns "--cookies /path" only when the file exists and has real cookie rows.
# Prevents yt-dlp warnings about empty/invalid cookie files.
_cookies_arg() {
    if [[ -f "$COOKIES_FILE" ]] && grep -qv "^#" "$COOKIES_FILE" 2>/dev/null; then
        printf -- "--cookies %s" "$COOKIES_FILE"
    fi
}

# Allow config file to override DOWNLOAD_DIR; fall back to default if unset
DOWNLOAD_DIR="${DOWNLOAD_DIR:-$HOME/videos/yt-dlp}"
mkdir -p "$DOWNLOAD_DIR"

# --- COOKIE SETUP ---
# Reads directly from Firefox's SQLite database (safe copy, no lock issues).
setup_cookies() {
    mkdir -p "$CONFIG_DIR"
    echo -e "\n🍪 Exporting cookies from \033[1;36mFirefox\033[0m → \033[1;33m$COOKIES_FILE\033[0m"
    echo -e "\033[0;90m   Firefox can be open — we read from a safe copy.\033[0m\n"

    # Find the active Firefox profile
    local ff_profile
    ff_profile=$(find "$HOME/.mozilla/firefox" -maxdepth 1 -name "*.default-release" -type d 2>/dev/null | head -n 1)
    [ -z "$ff_profile" ] && ff_profile=$(find "$HOME/.mozilla/firefox" -maxdepth 1 -name "*.default*" -type d 2>/dev/null | head -n 1)
    if [ -z "$ff_profile" ]; then
        echo -e "\033[1;31m❌ Could not find a Firefox profile in ~/.mozilla/firefox\033[0m"
        exit 1
    fi
    echo -e "  Profile: \033[0;90m$(basename "$ff_profile")\033[0m\n"

    # Copy the SQLite file so we don't hit Firefox's WAL lock
    local tmp_db
    tmp_db=$(mktemp /tmp/vid-cli-cookies-XXXXXX.sqlite)
    cp "$ff_profile/cookies.sqlite" "$tmp_db" 2>/dev/null || {
        echo -e "\033[1;31m❌ Could not copy cookies.sqlite from Firefox profile\033[0m"
        rm -f "$tmp_db"
        exit 1
    }
    cp "$ff_profile/cookies.sqlite-wal" "${tmp_db}-wal" 2>/dev/null || true
    cp "$ff_profile/cookies.sqlite-shm" "${tmp_db}-shm" 2>/dev/null || true

    # Export in Netscape cookie file format using Python — avoids awk field
    # splitting bugs when cookie values contain pipe characters.
    python3 - "$tmp_db" "$COOKIES_FILE" << 'PYEOF'
import sys, sqlite3

db_path, out_path = sys.argv[1], sys.argv[2]
domains = ("%youtube.com", "%google.com", "%ytimg.com", "%googlevideo.com")

rows = []
try:
    con = sqlite3.connect(db_path)
    cur = con.cursor()
    placeholders = " OR ".join("host LIKE ?" for _ in domains)
    cur.execute(f"""
        SELECT host, path, isSecure, expiry, name, value
        FROM moz_cookies
        WHERE {placeholders}
    """, domains)
    rows = cur.fetchall()
    con.close()
except Exception as e:
    print(f"sqlite error: {e}", file=sys.stderr)
    sys.exit(1)

with open(out_path, "w") as f:
    f.write("# Netscape HTTP Cookie File\n")
    f.write("# Exported by vid-cli\n")
    for host, path, is_secure, expiry, name, value in rows:
        # Netscape format: domain \t include_subdomains \t path \t secure \t expiry \t name \t value
        include_sub = "TRUE" if host.startswith(".") else "FALSE"
        secure      = "TRUE" if is_secure else "FALSE"
        f.write(f"{host}\t{include_sub}\t{path}\t{secure}\t{expiry}\t{name}\t{value}\n")

print(f"Wrote {len(rows)} cookies", file=sys.stderr)
PYEOF

    rm -f "$tmp_db" "${tmp_db}-wal" "${tmp_db}-shm"

    local count
    count=$(grep -vc "^#" "$COOKIES_FILE" 2>/dev/null || echo 0)

    if [ "$count" -gt 0 ]; then
        echo -e "\033[1;32m✅ Exported $count cookies\033[0m to \033[1;33m$COOKIES_FILE\033[0m"
        echo -e "\033[0;90m   Run 'vid-cli --setup' if downloads start failing (cookies expired).\033[0m\n"
    else
        echo -e "\033[1;31m❌ No YouTube cookies found. Are you signed in to YouTube in Firefox?\033[0m"
        rm -f "$COOKIES_FILE"
        exit 1
    fi
}

query="$1"

case "$query" in
    -v|--version) echo "vid-cli v$version_number"; exit 0 ;;
    -h|--help) help_info ;;
    -s|--setup) setup_cookies; exit 0 ;;
esac

# Auto-run setup if cookies file doesn't exist yet
if [ ! -f "$COOKIES_FILE" ]; then
    echo -e "\n\033[1;33m⚠️  No cookies file found.\033[0m Running first-time setup..."
    setup_cookies
fi

# --- 2. STARTUP MENU ---
# Clear yt search cache once per session so re-runs never show stale results
rm -f /tmp/vid-cli-yt-cache.txt /tmp/vid-cli-yt-last-query \
      /tmp/vid-cli-music-cache.txt /tmp/vid-cli-music-last-query

if [ -z "$query" ]; then
    print_banner

    while true; do
        mode=$(printf "  🎬  Watch Videos\n  🎵  Download Audio" \
            | fzf --prompt="  ❯ " \
                  --border=rounded \
