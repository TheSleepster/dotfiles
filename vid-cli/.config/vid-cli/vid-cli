                    done

                else
                    file_count=$(find "$DOWNLOAD_DIR" -type f ! -name "*.part" | wc -l)
                    if [ "$file_count" -eq 0 ]; then
                        echo "  ⚠️  No downloads found in $DOWNLOAD_DIR."
