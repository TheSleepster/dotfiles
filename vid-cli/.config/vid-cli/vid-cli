# Show a thumbnail above current cursor position given a URL
_show_thumb() {
    local url="$1" size="${2:-60x15}"
    [[ -z "$url" || "$url" == "NA" || "$url" == "None" ]] && return 0
    local key tfile
    key=$(printf '%s' "$url" | md5sum | cut -d" " -f1)
    tfile="/tmp/vid-cli-thumbs/${key}.jpg"
    mkdir -p /tmp/vid-cli-thumbs
    [[ ! -s "$tfile" ]] && curl -s --max-time 8 "$url" -o "$tfile" 2>/dev/null
    [[ -s "$tfile" ]] && chafa --size="$size" "$tfile" 2>/dev/null
    return 0
}

# Search/browse YouTube livestreams (live now + past VODs)
# Helper: pick quality, pick play mode, then stream or download a video.
# Works for regular videos, VODs, and live streams — no special casing needed.
_yt_play_video() {
    local video_id="$1"
    local video_url="https://www.youtube.com/watch?v=${video_id}"

    local quality
    quality=$(printf "1. 1080p (FHD)\n2. 720p (HD)\n3. 480p (SD)\n4. 360p (Low)\n5. Best Available\n↩  Cancel" \
        | launcher "⚙️  Quality: " "12")
    [[ -z "$quality" || "$quality" == *"Cancel"* ]] && return 1

    # For streaming: use best[height<=N] (pre-merged single stream).
    # bestvideo+bestaudio requires separate streams to exist, which many YouTube
    # videos don't have — the + format fails during yt-dlp's -J metadata phase.
    # For downloads: bestvideo+bestaudio is fine since ffmpeg merges on disk.
    local format
    case "$quality" in
        *1080p*) format="bestvideo[height<=1080]+bestaudio/best[height<=1080]/best" ;;
        *720p*)  format="bestvideo[height<=720]+bestaudio/best[height<=720]/best"   ;;
        *480p*)  format="bestvideo[height<=480]+bestaudio/best[height<=480]/best"   ;;
        *360p*)  format="bestvideo[height<=360]+bestaudio/best[height<=360]/best"   ;;
        *)       format="bestvideo+bestaudio/best"                                  ;;
    esac

    local play_mode
    play_mode=$(printf "  📡  Stream\n  ⬇️   Download and play\n  ↩   Cancel" \
        | fzf --prompt="  ❯ " --border=rounded --layout=reverse --height=8 --no-info \
              --color="prompt:#00afff,pointer:#00afff,hl:#00afff,hl+:#00afff")
    [[ -z "$play_mode" || "$play_mode" == *"Cancel"* ]] && return 1

    case "$play_mode" in
        *"Stream"*)
            local mpv_log="/tmp/vid-cli-mpv-$$.log"
            echo -e "📡 Launching \033[1;32mmpv\033[0m in background..."
            echo "  Log: $mpv_log"
            # Build ytdl-raw-options:
            #   jsi-engine=bun  — forces bun as the JS runtime for yt-dlp's
            #                     n-challenge solver (deno is broken on this system)
            # cookies= only appended when the file actually exists and has rows.
            # Use bun as JS runtime for yt-dlp's n-challenge solver.
            # Cookies are intentionally omitted from streaming — expired cookies
            # cause yt-dlp to fail entirely. Run vid-cli --setup to refresh them.
            # For bot-checked videos, refresh cookies then stream will work.
            local _ytdl_opts="js-runtimes=bun,remote-components=ejs:npm"
            mpv --config-dir="$HOME/.config/mpv" \
                --ytdl-format="$format" \
                --hwdec=auto-safe \
                --ytdl-raw-options="$_ytdl_opts" \
                "$video_url" >"$mpv_log" 2>&1 &
            local mpv_pid=$!
            disown $mpv_pid
            sleep 1
            if ! kill -0 "$mpv_pid" 2>/dev/null; then
                echo -e "\033[1;31m❌ mpv failed. Log: $mpv_log\033[0m"
                grep -v "^$" "$mpv_log" 2>/dev/null | tail -20 | sed "s/^/  /"
            else
                echo "✅ mpv launched (pid $mpv_pid) — stream running in background."
            fi
            ;;
        *)
            local existing_file
            existing_file=$(find "$DOWNLOAD_DIR" -type f -name "*${video_id}*" ! -name "*.part" | head -n 1)
            if [[ -n "$existing_file" ]]; then
                echo -e "✅ Already downloaded: \033[1;32m$(basename "$existing_file")\033[0m"
            else
                echo -e "⬇️  Downloading to \033[1;33m$DOWNLOAD_DIR\033[0m..."
                yt-dlp \
                    --js-runtimes bun --remote-components ejs:npm \
                    --format "$format" --merge-output-format mkv \
                    --output "$DOWNLOAD_DIR/%(title)s [%(id)s].%(ext)s" \
                    "$video_url"
                existing_file=$(find "$DOWNLOAD_DIR" -type f -name "*${video_id}*" ! -name "*.part" | head -n 1)
                [[ -z "$existing_file" ]] && { echo "❌ Download failed."; return 1; }
                echo -e "✅ Download complete: \033[1;32m$(basename "$existing_file")\033[0m"
            fi
            echo -e "▶️  Opening with \033[1;32mmpv\033[0m..."
            mpv --config-dir="$HOME/.config/mpv" --hwdec=auto-safe "$existing_file" >/dev/null 2>&1
            echo "✅ Playback finished."
            ;;
    esac
}
