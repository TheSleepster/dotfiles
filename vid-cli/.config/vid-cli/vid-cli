pick_format() {
    local fmt
    fmt=$(printf "  🔷  FLAC  — lossless (recommended)\n  🎧  MP3   — lossy, smallest\n  🔶  WAV   — uncompressed PCM\n  ↩   Cancel" \
        | fzf --prompt="  ❯ Format: " \
              --border=rounded --layout=reverse --height=9 --no-info \
              --color="prompt:#1db954,pointer:#1db954,hl:#1db954,hl+:#1db954")
    [[ -z "$fmt" || "$fmt" == *"Cancel"* ]] && return 1
    case "$fmt" in *FLAC*) echo "flac" ;; *MP3*) echo "mp3" ;; *WAV*) echo "wav" ;; esac
}

pick_dest_dir() {
    local music_root="${MUSIC_DIR:-$HOME/Music}"
    mkdir -p "$music_root"
    local choice
    choice=$(
        { echo "  🏠  ${music_root/$HOME\//.~\/} (root)"
          echo "  ➕  [ New folder ]"
          find "$music_root" -mindepth 1 -maxdepth 3 -type d 2>/dev/null \
              | sort | sed "s|$music_root/||"
        } | fzf --prompt="  ❯ Save to: " \
                --border=rounded --layout=reverse --height=40% --no-info \
                --header="  Choose destination" \
                --color="prompt:#1db954,pointer:#1db954,hl:#1db954,hl+:#1db954")
    [[ -z "$choice" ]] && return 1
    if [[ "$choice" == *"(root)"* ]]; then
        echo "$music_root"
    elif [[ "$choice" == *"New folder"* ]]; then
        local new_folder
        # stty sane + prompt + read all go through /dev/tty because this function
        # is called inside $() — stdout is captured, not the terminal.
        stty sane </dev/tty 2>/dev/null || true
        printf "\n  Folder name (under %s): " "${music_root/$HOME/~}" >/dev/tty
        read -r new_folder </dev/tty
        # Strip carriage returns and leading/trailing whitespace
        new_folder=$(printf '%s' "$new_folder" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [[ -z "$new_folder" || "$new_folder" == */* ]]; then
            printf "  \033[1;31m❌ Invalid folder name.\033[0m\n" >/dev/tty
            return 1
        fi
        mkdir -p "$music_root/$new_folder" || {
            printf "  \033[1;31m❌ Could not create folder: %s\033[0m\n" "$new_folder" >/dev/tty
            return 1
        }
        echo "$music_root/$new_folder"
    else
        echo "$music_root/$choice"
    fi
}

