# Direct YouTube audio search — user sees raw results and picks the exact source
_yt_audio_search() {
    local _yt_search_preview
    _yt_search_preview='
        title=$(echo {} | awk -F" ::: " "{print \$1}" | sed "s/^[[:space:]]*//")
        meta=$(echo {}  | awk -F" ::: " "{print \$2}")
        thumb=$(echo {} | awk -F" ::: " "{print \$5}")
        printf "\033[1;37m%s\033[0m\n\033[0;90m%s\033[0m\n\n" "$title" "$meta"
        if [ -n "$thumb" ] && [ "$thumb" != "NA" ] && [ "$thumb" != "None" ]; then
            cache_dir="/tmp/vid-cli-sp-thumbs"
            mkdir -p "$cache_dir"
            key=$(echo "$thumb" | md5sum | cut -d" " -f1)
            cache_file="$cache_dir/${key}.jpg"
            [ ! -f "$cache_file" ] && curl -s --max-time 8 "$thumb" -o "$cache_file" 2>/dev/null
            [ -s "$cache_file" ] && chafa --size="${FZF_PREVIEW_COLUMNS}x$((FZF_PREVIEW_LINES-5))" "$cache_file" 2>/dev/null
        fi
    '

    # Write the YouTube search script (reuses yt-dlp ytsearch:)
    local _yt_aud_script="/tmp/vid-cli-yt-aud-search.sh"
    cat > "$_yt_aud_script" << 'SEARCHEOF'
#!/bin/bash
query="$1"
[[ ${#query} -lt 2 ]] && exit 0
cache_q="/tmp/vid-cli-ytaud-last-query"
cache_f="/tmp/vid-cli-ytaud-cache.txt"
if [[ -f "$cache_q" && -f "$cache_f" ]]; then
    [[ "$(cat "$cache_q")" == "$query" ]] && cat "$cache_f" && exit 0
fi
yt-dlp     --flat-playlist     --print "%(id)s|||%(title)s|||%(channel)s|||%(duration_string)s|||%(thumbnail)s"     "ytsearch20:${query}" 2>/dev/null | python3 -c "
import sys, re
for line in sys.stdin:
    parts = line.strip().split('|||')
    if len(parts) < 2: continue
    vid_id = parts[0]
    if not re.fullmatch(r'[A-Za-z0-9_-]{11}', vid_id): continue
    title  = parts[1]
    ch     = parts[2] if len(parts) > 2 else ''
    dur    = parts[3] if len(parts) > 3 else ''
    thumb  = parts[4] if len(parts) > 4 else ''
    thumb  = '' if thumb in ('NA','None','none') else thumb
    if not thumb and vid_id:
        thumb = f'https://img.youtube.com/vi/{vid_id}/maxresdefault.jpg'
    meta = ' · '.join(p for p in [ch, dur] if p and p not in ('NA','None'))
    print(f'  🎬  {title} ::: {meta} ::: {vid_id} ::: ytvideo ::: {thumb}')
" | tee "$cache_f"
echo "$query" > "$cache_q"
SEARCHEOF
    chmod +x "$_yt_aud_script"

    local yt_sel
    yt_sel=$(: | fzf         --prompt="  🔍 Search YouTube: "         --header="  Type to search YouTube directly — pick the exact source to download"         --border=rounded --layout=reverse --height=85%         --disabled         --delimiter=" ::: " --with-nth=1,2         --preview="$_yt_search_preview"         --preview-window="right:40%:wrap"         --color="prompt:#ff6600,pointer:#ff6600,hl:#ff6600,hl+:#ff6600,header:#888888"         --bind "change:reload:bash $_yt_aud_script {q}"         --bind "start:reload:cat /tmp/vid-cli-ytaud-cache.txt 2>/dev/null || true"         --bind "resize:execute-silent(rm -f /tmp/vid-cli-sp-thumbs/.last_img_key 2>/dev/null)+refresh-preview") || { _clear_graphics; return; }

    _clear_graphics
    [[ -z "$yt_sel" ]] && return

    local vid_id vid_title
    vid_id=$(_fld "$yt_sel" 3)
    vid_title=$(_track_name "$yt_sel")
    [[ -z "$vid_id" ]] && return

    local ext dest_dir
    ext=$(pick_format)        || return
    dest_dir=$(pick_dest_dir) || return

    local log_idx=$(( ${#AUDIO_JOBS[@]} + 1 ))
    local logfile="/tmp/vid-cli-job${log_idx}.log"
    local donefile="/tmp/vid-cli-job${log_idx}.done"

    printf "\n  ⬇️  Queued [#%d]: \033[0;37m%s\033[0m [\033[1;36m%s\033[0m]\n" \
        "$log_idx" "$vid_title" "${ext^^}"

    local _vid_id="$vid_id" _vid_title="$vid_title"
    local _vid_cookies="--js-runtimes bun --remote-components ejs:npm"
    local safe_title
    local _vid_ext="$ext" _vid_dest="$dest_dir"
    safe_title=$(echo "$vid_title" | tr '/:*?"<>|\\' '_')

    # Ensure destination exists before backgrounding — the subshell cannot prompt
    mkdir -p "$_vid_dest" || {
        echo -e "  \033[1;31m❌ Could not create destination: $_vid_dest\033[0m"
        return 1
    }

    (
        # ── 1. Fetch yt-dlp metadata (title, channel, thumbnail URL) ──────────
        # Use separate --print flags so each value is on its own line —
        # avoids awk -F'|||' which treats ||| as a regex and splits wrong.
        local yt_meta
        yt_meta=$(yt-dlp --no-playlist \
            --print "%(title)s" \
            --print "%(channel)s" \
            --print "%(thumbnail)s" \
            "https://www.youtube.com/watch?v=${_vid_id}" 2>/dev/null)
        local yt_title yt_channel yt_thumb
        yt_title=$(printf '%s' "$yt_meta"   | sed -n '1p')
        yt_channel=$(printf '%s' "$yt_meta" | sed -n '2p')
        yt_thumb=$(printf '%s' "$yt_meta"   | sed -n '3p')
        # Fall back to user-visible title if yt-dlp returns nothing
        yt_title="${yt_title:-$_vid_title}"
        yt_channel="${yt_channel:-}"

        # ── 2. Download audio ─────────────────────────────────────────────────
        yt-dlp \
            $_vid_cookies \
            --extract-audio \
            --audio-format "$_vid_ext" \
            --audio-quality 0 \
            --output "${_vid_dest}/${safe_title}.%(ext)s" \
            --no-playlist \
            "https://www.youtube.com/watch?v=${_vid_id}" \
            >> "$logfile" 2>&1

        if [[ $? -ne 0 ]]; then
            echo "FAILED" > "$donefile"; exit 1
        fi

        # ── 3. Locate downloaded file ─────────────────────────────────────────
        local found
        found=$(find "$_vid_dest" -maxdepth 1 \
            -name "${safe_title}.*" \
            ! -name "*.part" ! -name "*.ytdl" ! -name "*.tmp" \
            2>/dev/null | head -1)

        if [[ -z "$found" || ! -f "$found" ]]; then
            echo "FILE_NOT_FOUND" >> "$logfile"
            echo "FAILED" > "$donefile"; exit 1
        fi

        # ── 4. Fetch cover art ────────────────────────────────────────────────
        # Use the YouTube thumbnail; try maxres → hq fallback
        local cover_file="/tmp/vid-cli-cover-${log_idx}.jpg"
        if [[ -n "$yt_thumb" && "$yt_thumb" != "NA" ]]; then
            curl -s --max-time 15 "$yt_thumb" -o "$cover_file" 2>/dev/null
        fi
        # If thumbnail fetch failed, try the standard maxres URL
        if [[ ! -s "$cover_file" ]]; then
            curl -s --max-time 10 \
                "https://img.youtube.com/vi/${_vid_id}/maxresdefault.jpg" \
                -o "$cover_file" 2>/dev/null
            [[ ! -s "$cover_file" ]] && \
                curl -s --max-time 10 \
                    "https://img.youtube.com/vi/${_vid_id}/hqdefault.jpg" \
                    -o "$cover_file" 2>/dev/null
        fi

        # ── 5. Embed metadata + cover (same logic as queue_download) ──────────
        local tmp="${found}.tmp"
        local _tmp="${found}.tmp"
        case "$_vid_ext" in
            flac)
                metaflac --remove-all-tags "$found" 2>>"$logfile"
                metaflac --set-tag="TITLE=${yt_title}"    "$found" 2>>"$logfile"
                metaflac --set-tag="ARTIST=${yt_channel}" "$found" 2>>"$logfile"
                [[ -s "$cover_file" ]] && \
                    metaflac --import-picture-from="3||||${cover_file}" \
                        "$found" 2>>"$logfile"
                ;;
            mp3)
                local _fargs=(-i "$found" -map 0 -c copy
                    -metadata "title=${yt_title}"
                    -metadata "artist=${yt_channel}")
                [[ -s "$cover_file" ]] && \
                    _fargs+=(-i "$cover_file" -map 0 -map 1 \
                             -metadata:s:v title="Album cover" \
                             -metadata:s:v comment="Cover (front)")
                ffmpeg -loglevel error "${_fargs[@]}" "$_tmp" >> "$logfile" 2>&1 \
                    && mv "$_tmp" "$found" || rm -f "$_tmp"
                ;;
            *)
                ffmpeg -loglevel error \
                    -i "$found" -map 0 -c copy \
                    -metadata "title=${yt_title}" \
                    -metadata "artist=${yt_channel}" \
                    "$_tmp" >> "$logfile" 2>&1 \
                    && mv "$_tmp" "$found" || rm -f "$_tmp"
                ;;
        esac

        rm -f "$cover_file"
        echo "OK" > "$donefile"
        exit 0
    ) &

    AUDIO_JOBS+=("$!|${vid_title}|${dest_dir}|${ext}|${logfile}|${donefile}")
}

youtube_home_page() {
