    local cookies_flag=()
    [[ -f "$COOKIES_FILE" ]] && grep -qv "^#" "$COOKIES_FILE" 2>/dev/null &&         cookies_flag=(--cookies "$COOKIES_FILE")

    local lines
    lines=$(yt-dlp "${cookies_flag[@]}"         --flat-playlist         --print "%(title)s|||%(id)s|||%(channel)s|||%(duration_string)s|||%(thumbnail)s"         "https://www.youtube.com/" 2>/dev/null     | python3 -c "
import sys, re
for i, line in enumerate(sys.stdin, 1):
    parts = line.strip().split('|||')
    if len(parts) < 2: continue
    title   = parts[0]
    vid_id  = parts[1]
    if not re.fullmatch(r'[A-Za-z0-9_-]{11}', vid_id): continue
    channel = parts[2] if len(parts) > 2 else ''
    dur     = parts[3] if len(parts) > 3 else ''
    thumb   = parts[4] if len(parts) > 4 else ''
    thumb   = '' if thumb in ('NA','None','none') else thumb
    if not thumb:
        thumb = f'https://img.youtube.com/vi/{vid_id}/maxresdefault.jpg'
    meta = ' · '.join(p for p in [channel, dur] if p and p not in ('NA','None'))
    print(f'  {i:02d}  {title} ::: {meta} ::: {vid_id} ::: video ::: {thumb}')
")

    [[ -z "$lines" ]] && {
        echo -e "  \033[1;31m❌ Could not load YouTube home. Are you signed in? Try vid-cli --setup.\033[0m"
