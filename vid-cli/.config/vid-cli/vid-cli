# Extract field N (1-based) from a " ::: "-delimited fzf line
_fld() { printf '%s' "$1" | awk -F' ::: ' "{print \$$2}"; }

# Extract clean track title from field 1: strip leading space, collapse
# repeated spaces, drop " ·  rest" suffix
_track_name() { printf '%s' "$1" | awk -F' ::: ' '{print $1}' | sed 's/^[[:space:]]*//' | sed 's/  */ /g' | sed 's/ ·.*//'; }

# Queue every newline-separated line from $1 for download.
# $1=lines $2=fallback_artist $3=album $4=fallback_cover $5=ext $6=dest_dir
_queue_lines() {
    local _lines="$1" _artist="$2" _album="$3" _cover="$4" _ext="$5" _dest="$6"
    while IFS= read -r _l; do
        local _tid _tname _tart _timg
        _tid=$(_fld  "$_l" 3)
        _tname=$(_track_name "$_l")
        _tart=$(_fld "$_l" 5)
        _timg=$(_fld "$_l" 4)
        [[ -z "$_tid" ]] && continue
        local _a="${_tart:-$_artist}"
        local _c="${_timg:-$_cover}"
        queue_download "${_tname} — ${_a}" "$_a" "$_tname" "$_album" "$_c" "$_ext" "$_dest" "$_tid"
    done <<< "$_lines"
}

# Shared fzf browser for YouTube video line lists.
# $1=header  $2=lines — prints selected line; returns 1 on ESC.
_yt_video_fzf() {
    local _hdr="$1" _lines="$2"
    printf '%s' "$_lines"         | fzf --prompt="  ❯ "               --header="  ${_hdr}"               --border=rounded --layout=reverse --height=85%               --delimiter=" ::: " --with-nth=1,2               --preview="$PREVIEW_SCRIPT"               --bind "resize:execute-silent(rm -f /tmp/vid-cli-thumbs/.last_img_key 2>/dev/null)+refresh-preview"               --preview-window="right:40%:wrap"               --color="prompt:#00afff,pointer:#00afff,hl:#00afff,hl+:#00afff,header:#888888"
}

# Clears any kitty/iTerm inline image left on screen by fzf preview
_clear_graphics() {
    printf "\033_Ga=d\033\\"
