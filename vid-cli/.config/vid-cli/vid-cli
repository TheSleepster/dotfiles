# --- THUMBNAIL PREVIEW HELPER ---
# Line format: DISPLAY :: META :: ID :: TYPE
# TYPE is "video", "channel", or "playlist"
# Line format: DISPLAY ::: META ::: ID ::: TYPE ::: THUMB_URL
PREVIEW_SCRIPT='
    entry_type=$(echo {} | awk -F " ::: " "{print \$4}")
    item_id=$(echo {}    | awk -F " ::: " "{print \$3}")
    title=$(echo {}      | awk -F " ::: " "{print \$1}" | sed "s/^[[:space:]]*//")
    meta=$(echo {}       | awk -F " ::: " "{print \$2}")
    thumb_url=$(echo {}  | awk -F " ::: " "{print \$5}")
    printf "\033[1;37m%s\033[0m\n" "$title"
    printf "\033[0;90m%s\033[0m\n\n" "$meta"
    cache_dir="/tmp/vid-cli-thumbs"
    mkdir -p "$cache_dir"
    sentinel="$cache_dir/.last_img_key"
    _draw_image() {
        local img_file="$1" new_key="$2"
        local last_key; last_key=$(cat "$sentinel" 2>/dev/null)
        if [ "$new_key" = "$last_key" ]; then
            # Same image — redraw without clearing (fzf already cleared text)
            chafa --size="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}" "$img_file" 2>/dev/null
            return
        fi
        # Different image — send Kitty delete-all then redraw
        printf "\033_Ga=d\033\\"
        chafa --size="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}" "$img_file" 2>/dev/null
        printf "%s" "$new_key" > "$sentinel"
    }
    if [ "$entry_type" = "video" ]; then
        cache_file="$cache_dir/$item_id.jpg"
        if [ ! -f "$cache_file" ]; then
            curl -s --max-time 5 "https://img.youtube.com/vi/$item_id/maxresdefault.jpg" -o "$cache_file" 2>/dev/null
            size=$(wc -c < "$cache_file" 2>/dev/null || echo 0)
            [ "$size" -lt 5000 ] && curl -s --max-time 5 "https://img.youtube.com/vi/$item_id/sddefault.jpg" -o "$cache_file" 2>/dev/null
        fi
        if [ -s "$cache_file" ]; then
            _draw_image "$cache_file" "$item_id"
        else
            printf "\033_Ga=d\033\\"
            printf "\033[0;31m(thumbnail unavailable)\033[0m\n"
            printf "" > "$sentinel"
            rm -f "$cache_file"
        fi
    elif [ "$entry_type" = "playlist" ] || [ "$entry_type" = "channel" ]; then
        if [ -n "$thumb_url" ] && [ "$thumb_url" != "NA" ] && [ "$thumb_url" != "None" ]; then
            key=$(echo "$thumb_url" | md5sum | cut -d" " -f1)
            cache_file="$cache_dir/${key}.jpg"
            [ ! -s "$cache_file" ] && curl -s --max-time 8 "$thumb_url" -o "$cache_file" 2>/dev/null
            [ -s "$cache_file" ] && _draw_image "$cache_file" "$key"
        fi
        if [ "$entry_type" = "channel" ]; then
            printf "\033[1;36m📺  YouTube Channel\033[0m\n"
            printf "\033[0;90m  Press ENTER to browse videos & playlists\033[0m\n"
        else
            printf "\033[1;33m📋  YouTube Playlist\033[0m\n"
            printf "\033[0;90m  Press ENTER to browse videos\033[0m\n"
        fi
    fi
'

# --- YOUTUBE SEARCH SCRIPT (written at runtime so $COOKIES_FILE is embedded) ---
_write_yt_search_script() {
    cat > /tmp/vid-cli-yt-search.sh << SEARCHEOF
#!/bin/bash
query="\$1"
[[ \${#query} -lt 3 ]] && exit 0

cache_query_file="/tmp/vid-cli-yt-last-query"
cache_file="/tmp/vid-cli-yt-cache.txt"
if [[ -f "\$cache_query_file" && -f "\$cache_file" ]]; then
    [[ "\$(cat "\$cache_query_file")" == "\$query" ]] && cat "\$cache_file" && exit 0
fi

encoded=\$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "\$query" 2>/dev/null)
tf=\$(mktemp /tmp/vid-cli-yt-XXXXXX.txt)

yt-dlp "https://www.youtube.com/results?search_query=\${encoded}" \\
    --cookies "${COOKIES_FILE}" \\
    --flat-playlist \\
    -I 1:20 \\
    --print "%(title)s|||%(webpage_url)s|||%(id)s|||%(uploader)s|||%(duration_string)s|||%(playlist_count)s|||%(thumbnail)s" \\
    2>/dev/null > "\$tf"

python3 - "\$tf" "\$cache_file" << 'PYEOF'
import sys

lines = []
with open(sys.argv[1]) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        parts = line.split("|||")
        if len(parts) < 3: continue
        title    = parts[0]
        url      = parts[1]
        item_id  = parts[2]
        uploader = parts[3] if len(parts) > 3 else ""
        dur      = parts[4] if len(parts) > 4 else ""
        count    = parts[5] if len(parts) > 5 else ""
        thumb    = parts[6] if len(parts) > 6 else ""

        # yt-dlp sometimes emits literal "NA" — treat as empty
        thumb = "" if thumb in ("NA", "None", "none") else thumb

        if "/channel/" in url or "/@" in url or "/user/" in url:
            lines.append(f"  📺  {title} ::: YouTube Channel ::: {url} ::: channel ::: {thumb}")
        elif "playlist?list=" in url or "/playlist/" in url:
            # count from search API is often "NA" — only show real numbers
            try:
                n = f"{int(count)} videos"
            except (ValueError, TypeError):
                n = "Playlist"
            meta = " · ".join(p for p in [uploader, n] if p)
            lines.append(f"  📋  {title} ::: {meta} ::: {url} ::: playlist ::: {thumb}")
        else:
            meta = " · ".join(p for p in [uploader, dur] if p)
            lines.append(f"  🎬  {title} ::: {meta} ::: {item_id} ::: video ::: https://img.youtube.com/vi/{item_id}/mqdefault.jpg")

result = "\n".join(lines)
print(result)
with open(sys.argv[2], "w") as f:
    f.write(result + "\n")
PYEOF

echo "\$query" > "\$cache_query_file"
rm -f "\$tf"
SEARCHEOF
    chmod +x /tmp/vid-cli-yt-search.sh
}


# --- SHARED LIVE SEARCH ---
run_search() {
    local prompt="$1" query="$2"
    _write_yt_search_script
    : | fzf --prompt="$prompt" \
            --border=rounded \
            --layout=reverse \
            --height=80% \
            --disabled \
            --print-query \
            --delimiter=" ::: " \
            --with-nth=1,2 \
            --preview="$PREVIEW_SCRIPT" \
            --bind "resize:execute-silent(rm -f /tmp/vid-cli-thumbs/.last_img_key 2>/dev/null)+refresh-preview" \
            --preview-window="right:40%:wrap" \
            --color="prompt:#00afff,pointer:#00afff,hl:#00afff,hl+:#00afff" \
            --query="$query" \
            --bind "change:reload:bash /tmp/vid-cli-yt-search.sh {q}" \
            --bind "start:reload:cat /tmp/vid-cli-yt-cache.txt 2>/dev/null || bash /tmp/vid-cli-yt-search.sh {q}" \
            --header="  Type to search — 📺 channels  📋 playlists  🎬 videos"
}


# --- BACKGROUND JOB TRACKING ---
AUDIO_JOBS=()

check_audio_jobs() {
    [[ ${#AUDIO_JOBS[@]} -eq 0 ]] && return
    local remaining=()
    for job in "${AUDIO_JOBS[@]}"; do
        local pid title dest ext logfile donefile
        IFS='|' read -r pid title dest ext logfile donefile <<< "$job"
        if kill -0 "$pid" 2>/dev/null; then
            printf "  ⏳ \033[0;33mRunning:\033[0m %s\n" "$title"
            remaining+=("$job")
        else
            wait "$pid"
            local status
            status=$(cat "$donefile" 2>/dev/null)
            if [[ "$status" == "OK" ]]; then
                printf "  ✅ \033[1;32mDone:\033[0m %s [%s]\n" "$title" "${ext^^}"
            else
                printf "  ❌ \033[1;31mFailed:\033[0m %s\n" "$title"
                if [[ -f "$logfile" ]]; then
                    printf "  \033[0;90m--- %s ---\033[0m\n" "$logfile"
                    tail -n 10 "$logfile" | sed 's/^/     /'
                fi
            fi
            rm -f "$donefile"
        fi
    done
    AUDIO_JOBS=("${remaining[@]}")
}

cleanup() {
    rm -rf /tmp/vid-cli-thumbs /tmp/vid-cli-cover-*.jpg /tmp/vid-cli-*.log \
            /tmp/vid-cli-yt-cache.txt /tmp/vid-cli-yt-last-query \
            /tmp/vid-cli-yt-search.sh /tmp/vid-cli-music-search.sh \
            /tmp/vid-cli-sp-thumbs /tmp/vid-cli-cand-*.tsv /tmp/vid-cli-dz-*.json \
            /tmp/vid-cli-disco-*.txt /tmp/vid-cli-allvids-*.txt /tmp/vid-cli-ytaud-*.txt \
            /tmp/vid-cli-yt-aud-search.sh /tmp/vid-cli-music-cache.txt /tmp/vid-cli-music-last-query
    printf "\033[H\033[2J\033[3J"
    printf "\033_Ga=d\033\\"
    if [ ${#AUDIO_JOBS[@]} -gt 0 ]; then
        printf "\n\033[0;33m  ⏳ %d audio download(s) still running in the background:\033[0m\n" "${#AUDIO_JOBS[@]}"
        for job in "${AUDIO_JOBS[@]}"; do
            local title dest ext logfile
            local _pid _done
            IFS='|' read -r _pid title dest ext logfile _done <<< "$job"
            printf "    • %s  [%s → %s]\n" "$title" "${ext^^}" "$dest"
            [[ -n "$logfile" ]] && printf "      log: %s\n" "$logfile"
        done
        printf "\n"
    fi
}
trap cleanup EXIT

# =============================================================================
# DEEZER API — no credentials needed
# =============================================================================
# Line format: DISPLAY ::: TYPE ::: DEEZER_ID ::: IMG_URL ::: EXTRA

deezer_api() {
    curl -s --max-time 10 "https://api.deezer.com${1}" 2>/dev/null
}

MUSIC_PREVIEW='
    display=$(echo {} | awk -F" ::: " "{print \$1}" | sed "s/^[[:space:]]*//")
    extra=$(echo {}   | awk -F" ::: " "{print \$5}")
    img_url=$(echo {} | awk -F" ::: " "{print \$4}")
    printf "\033[1;37m%s\033[0m\n" "$display"
    [ -n "$extra" ] && printf "\033[0;90m%s\033[0m\n" "$extra"
    printf "\n"
    if [ -n "$img_url" ] && [ "$img_url" != "NA" ] && [ "$img_url" != "None" ]; then
        cache_dir="/tmp/vid-cli-sp-thumbs"
        mkdir -p "$cache_dir"
        sentinel="$cache_dir/.last_img_key"
        key=$(echo "$img_url" | md5sum | cut -d" " -f1)
        cache_file="$cache_dir/${key}.jpg"
        [ ! -f "$cache_file" ] && curl -s --max-time 8 "$img_url" -o "$cache_file" 2>/dev/null
        if [ -s "$cache_file" ]; then
            last_key=$(cat "$sentinel" 2>/dev/null)
            if [ "$key" != "$last_key" ]; then
                printf "\033_Ga=d\033\\"
                printf "%s" "$key" > "$sentinel"
            fi
            chafa --size="${FZF_PREVIEW_COLUMNS}x$((FZF_PREVIEW_LINES-4))" "$cache_file" 2>/dev/null
        fi
    else
        sentinel="/tmp/vid-cli-sp-thumbs/.last_img_key"
        last_key=$(cat "$sentinel" 2>/dev/null)
        if [ -n "$last_key" ]; then
            printf "\033_Ga=d\033\\"
            printf "" > "$sentinel"
        fi
    fi
'

_write_music_search_script() {
    cat > /tmp/vid-cli-music-search.sh << 'SEARCHEOF'
#!/bin/bash
query="$1"
[[ ${#query} -lt 2 ]] && exit 0

# Cache: skip Deezer fetch if query unchanged
cache_query_file="/tmp/vid-cli-music-last-query"
cache_file="/tmp/vid-cli-music-cache.txt"
if [[ -f "$cache_query_file" && -f "$cache_file" ]]; then
    [[ "$(cat "$cache_query_file")" == "$query" ]] && cat "$cache_file" && exit 0
fi

encoded=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$query" 2>/dev/null)

tf_a=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)
tf_b=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)
tf_t=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)
tf_p=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)

curl -s --max-time 8 "https://api.deezer.com/search/artist?q=${encoded}&limit=4"   -o "$tf_a" 2>/dev/null & _p1=$!
curl -s --max-time 8 "https://api.deezer.com/search/album?q=${encoded}&limit=4"    -o "$tf_b" 2>/dev/null & _p2=$!
curl -s --max-time 8 "https://api.deezer.com/search/track?q=${encoded}&limit=6"    -o "$tf_t" 2>/dev/null & _p3=$!
curl -s --max-time 8 "https://api.deezer.com/search/playlist?q=${encoded}&limit=3" -o "$tf_p" 2>/dev/null & _p4=$!
wait $_p1 $_p2 $_p3 $_p4

python3 - "$tf_a" "$tf_b" "$tf_t" "$tf_p" << 'PYEOF' | tee "$cache_file"
import sys, json

def load(p):
    try:
        with open(p) as f: return json.load(f).get("data", [])
    except: return []

def dur(s): return f"{s//60}:{s%60:02d}"

for a in load(sys.argv[1]):
    fans = a.get("nb_fan", 0)
    img  = a.get("picture_medium", "")
    print(f"  🎤  {a['name']} ::: artist ::: {a['id']} ::: {img} ::: {fans:,} fans")

for a in load(sys.argv[2]):
    art = a.get("artist", {}).get("name", "")
    img = a.get("cover_medium", "")
    n   = a.get("nb_tracks", "?")
    print(f"  💿  {a['title']} · {art} ::: album ::: {a['id']} ::: {img} ::: {art} · {n} tracks")

for t in load(sys.argv[3]):
    art = t.get("artist", {}).get("name", "")
    alb = t.get("album",  {}).get("title", "")
    img = t.get("album", {}).get("cover_xl") or t.get("album", {}).get("cover_medium", "")
    d   = dur(t.get("duration", 0))
    print(f"  🎵  {t['title']} · {art} ::: track ::: {t['id']} ::: {img} ::: {art} · {alb} · {d}")

import io, os, sys as _sys
_out = io.StringIO()
_orig_stdout = _sys.stdout
_sys.stdout = _out

for p in load(sys.argv[4]):
    user = p.get("user", {}).get("name", "")
    n    = p.get("nb_tracks", "?")
    img  = p.get("picture_medium", "")
    print(f"  📋  {p['title']} ::: playlist ::: {p['id']} ::: {img} ::: by {user} · {n} tracks")
PYEOF
echo "$query" > "$cache_query_file"
rm -f "$tf_a" "$tf_b" "$tf_t" "$tf_p"
SEARCHEOF
    chmod +x /tmp/vid-cli-music-search.sh
}

# =============================================================================
# MUSIC PAGE FUNCTIONS
# =============================================================================

music_tracklist_fzf() {
    local header="$1" lines="$2" all_label="$3"
    local full_list="$lines"
    [[ -n "$all_label" ]] && \
        full_list=$(printf '  ⬇️   %s ::: action ::: download_all ::: ::: \n%s' "$all_label" "$lines")

    local selected
    selected=$(printf '%s' "$full_list" \
        | fzf --prompt="  ❯ " \
              --header="  ${header}  ·  TAB to multi-select" \
              --border=rounded --layout=reverse --height=85% \
              --multi \
              --delimiter=" ::: " --with-nth=1 \
              --preview="$MUSIC_PREVIEW" \
              --bind "resize:execute-silent(rm -f /tmp/vid-cli-sp-thumbs/.last_img_key 2>/dev/null)+refresh-preview" \
              --preview-window="right:40%:wrap" \
              --color="prompt:#1db954,pointer:#1db954,hl:#1db954,hl+:#1db954,header:#888888")
    [[ -z "$selected" ]] && return 1
    printf '%s' "$selected"
}

# Shared fzf+download loop for album and playlist pages.
# $1=header $2=all_label $3=lines $4=artist $5=album $6=cover_url
_music_tracklist_page() {
    local header="$1" all_label="$2" lines="$3" artist="$4" album="$5" cover_url="$6"
    [[ -z "$lines" ]] && { echo -e "  \033[1;31m❌ Nothing to display.\033[0m\n"; return 1; }
    while true; do
        local selected
        selected=$(music_tracklist_fzf "$header" "$lines" "$all_label") || { _clear_graphics; return 0; }
        _clear_graphics
        local ext dest_dir
        ext=$(pick_format)        || continue
        dest_dir=$(pick_dest_dir) || continue
        local dl_lines="$selected"
        echo "$selected" | grep -q "action ::: download_all" && dl_lines="$lines"
        _queue_lines "$dl_lines" "$artist" "$album" "$cover_url" "$ext" "$dest_dir"
        continue
    done
}

music_album_page() {
    local album_id="$1"
    local jf; jf=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)
    deezer_api "/album/${album_id}" > "$jf"

    local album_name artist_name img_url release_year total_tracks lines
    album_name=$(python3  -c "import sys,json; d=json.load(open(sys.argv[1])); print(d.get('title',''))"                   "$jf" 2>/dev/null)
    artist_name=$(python3 -c "import sys,json; d=json.load(open(sys.argv[1])); print(d.get('artist',{}).get('name',''))" "$jf" 2>/dev/null)
    img_url=$(python3     -c "import sys,json; d=json.load(open(sys.argv[1])); print(d.get('cover_xl') or d.get('cover_medium',''))"            "$jf" 2>/dev/null)
    release_year=$(python3 -c "import sys,json; d=json.load(open(sys.argv[1])); print((d.get('release_date') or '')[:4])" "$jf" 2>/dev/null)
    total_tracks=$(python3 -c "import sys,json; d=json.load(open(sys.argv[1])); print(d.get('nb_tracks','?'))"            "$jf" 2>/dev/null)

    # Fetch ALL tracks, following Deezer pagination (next URL)
    lines=$(python3 - "$jf" "$album_id" << 'PYEOF'
import sys, json, urllib.request

d   = json.load(open(sys.argv[1]))
img = d.get("cover_xl") or d.get("cover_medium", "")

all_tracks = list(d.get("tracks", {}).get("data", []))
next_url   = d.get("tracks", {}).get("next", "")

while next_url:
    try:
        with urllib.request.urlopen(next_url, timeout=8) as r:
            page = json.loads(r.read())
        all_tracks.extend(page.get("data", []))
        next_url = page.get("next", "")
    except Exception:
        break

for t in all_tracks:
    n   = t.get("track_position", 0)
    s   = t.get("duration", 0)
    dur = f"{s//60}:{s%60:02d}"
    art = t.get("artist", {}).get("name", "")
    print(f"  {n:02d}  {t['title']}  ·  {dur} ::: track ::: {t['id']} ::: {img} ::: {art}")
PYEOF
    )
    rm -f "$jf"
    [[ -z "$lines" ]] && { echo -e "  \033[1;31m❌ Could not load album tracks.\033[0m\n"; return 1; }

    _music_tracklist_page \
        "💿 ${album_name} · ${artist_name} · ${release_year} · ${total_tracks} tracks" \
        "Download entire album" "$lines" "$artist_name" "$album_name" "$img_url"
}

music_playlist_page() {
    local playlist_id="$1"
    local jf; jf=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)
    deezer_api "/playlist/${playlist_id}" > "$jf"

    local pl_name owner img_url lines
    pl_name=$(python3 -c "import sys,json; d=json.load(open(sys.argv[1])); print(d.get('title',''))"                "$jf" 2>/dev/null)
    owner=$(python3   -c "import sys,json; d=json.load(open(sys.argv[1])); print(d.get('creator',{}).get('name',''))" "$jf" 2>/dev/null)
    img_url=$(python3 -c "import sys,json; d=json.load(open(sys.argv[1])); print(d.get('picture_xl') or d.get('picture_medium',''))"        "$jf" 2>/dev/null)

    lines=$(python3 - "$jf" << 'PYEOF'
import sys, json
d      = json.load(open(sys.argv[1]))
pl_img = d.get("picture_medium", "")
for i, t in enumerate(d.get("tracks", {}).get("data", []), 1):
    s   = t.get("duration", 0)
    dur = f"{s//60}:{s%60:02d}"
    art = t.get("artist", {}).get("name", "")
    img = t.get("album", {}).get("cover_xl") or t.get("album", {}).get("cover_medium", pl_img)
    print(f"  {i:02d}  {t['title']}  ·  {dur} ::: track ::: {t['id']} ::: {img} ::: {art}")
PYEOF
    )
    rm -f "$jf"
    [[ -z "$lines" ]] && { echo -e "  \033[1;31m❌ Could not load playlist tracks.\033[0m\n"; return 1; }

    _music_tracklist_page \
        "📋 ${pl_name} · by ${owner}" \
        "Download entire playlist" "$lines" "" "" "$img_url"
}

music_artist_page() {
    local artist_id="$1"
    local jf_a jf_t jf_b
    jf_a=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)
    jf_t=$(mktemp /tmp/vid-cli-dz-XXXXXX.json)
